<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Traveloop | Premium Journey Planning</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/js/utils.js"></script>
</head>
<body>
    <header>
        <nav class="container">
            <a href="/" class="logo">
                <i class="fas fa-plane-departure"></i>
                <span>Traveloop</span>
            </a>
            <ul class="nav-links">
                <% if (typeof user !== 'undefined' && user) { %>
                    <li><a href="/dashboard"><i class="fas fa-th-large"></i> Dashboard</a></li>
                    <li><a href="/my-trips"><i class="fas fa-map"></i> My Trips</a></li>
                    <li><a href="/trips/create" class="btn btn-primary btn-small">Plan Trip</a></li>
                    <li class="user-profile-badge">
                        <a href="/profile" style="text-decoration: none;">
                            <div class="avatar" style="width: 35px; height: 35px; font-size: 0.9rem;"><%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %></div>
                        </a>
                        <button id="logoutBtn" class="btn btn-outline btn-small" style="padding: 0.4rem 1rem;">Logout</button>
                    </li>
                <% } else { %>
                    <li><a href="/login">Login</a></li>
                    <li><a href="/signup" class="btn btn-primary">Start Planning</a></li>
                <% } %>
            </ul>
        </nav>
    </header>
    <main class="container animate-up" style="margin-top: 3rem; margin-bottom: 5rem;">

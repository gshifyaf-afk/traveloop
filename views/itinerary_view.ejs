<%- include('partials/header') %>

<div class="itinerary-view-header">
    <div style="display: flex; flex-direction: column; align-items: center; gap: 1rem;">
        <span class="badge" style="background: var(--primary-glow); color: var(--primary); padding: 0.5rem 1.5rem; border-radius: var(--radius-pill); font-weight: 800; font-size: 0.75rem; letter-spacing: 0.1em;">CONFIRMED JOURNEY</span>
        <h1 style="font-size: 3.5rem; margin-top: 0.5rem;"><%= trip.name %></h1>
        <p class="text-dim" style="max-width: 600px; font-size: 1.1rem;"><%= trip.description %></p>
        
        <div style="display: flex; gap: 1.5rem; margin-top: 2.5rem; flex-wrap: wrap; justify-content: center;">
            <button id="shareTrip" class="btn btn-primary">
                <i class="fas fa-share-nodes"></i> Share Journey
            </button>
            <a href="/trips/itinerary/<%= trip.id %>" class="btn btn-outline">
                <i class="fas fa-edit"></i> Edit Itinerary
            </a>
        </div>
    </div>
</div>

<div class="itinerary-main-grid">
    <section class="timeline-flow">
        <h2 style="margin-bottom: 3rem; display: flex; align-items: center; gap: 1rem;">
            <i class="fas fa-route" style="color: var(--primary);"></i> Journey Timeline
        </h2>
        
        <div id="itineraryTimeline" class="itinerary-timeline">
            <!-- Content injected via JS -->
            <div style="text-align: center; padding: 5rem;">
                <i class="fas fa-circle-notch fa-spin" style="font-size: 2rem; color: var(--primary);"></i>
                <p style="margin-top: 1rem; color: var(--text-dim);">Preparing your journey view...</p>
            </div>
        </div>
    </section>

    <aside class="itinerary-analytics">
        <div class="card glass-card">
            <h3 style="margin-bottom: 2rem;"><i class="fas fa-chart-line" style="margin-right: 0.5rem; color: var(--primary);"></i> Cost Breakdown</h3>
            <div style="height: 250px; margin-bottom: 2rem;">
                <canvas id="budgetChart"></canvas>
            </div>
            <div style="display: flex; flex-direction: column; gap: 1rem; padding-top: 2rem; border-top: 1px solid var(--glass-border);">
                <div style="display: flex; justify-content: space-between;">
                    <span class="text-dim">Total Estimated Cost</span>
                    <strong id="totalCost" style="font-size: 1.5rem; color: var(--primary);">₹0</strong>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span class="text-dim">Daily Average</span>
                    <strong id="avgPerDay">₹0</strong>
                </div>
                <div id="categoryBreakdown" style="margin-top: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem;"></div>
            </div>
            <div id="budgetAlerts" style="margin-top: 2rem;"></div>
        </div>
    </aside>
</div>

<script>
    const tripId = <%= trip.id %>;
    const publicToken = "<%= trip.public_token %>";

    document.addEventListener('DOMContentLoaded', async () => {
        await loadTimeline();
        await loadBudget();

        document.getElementById('shareTrip').onclick = () => {
            const url = `${window.location.origin}/shared/${publicToken}`;
            navigator.clipboard.writeText(url).then(() => {
                alert('Premium share link copied to clipboard!');
            });
        };
    });

    async function loadTimeline() {
        const stops = await apiFetch(`/api/stops?trip_id=${tripId}`);
        const container = document.getElementById('itineraryTimeline');
        container.innerHTML = '';

        if (stops.length === 0) {
            container.innerHTML = `<div class="card" style="text-align: center; padding: 4rem;">
                <p class="text-dim">Your timeline is empty. Start adding some destinations!</p>
            </div>`;
            return;
        }

        for (let i = 0; i < stops.length; i++) {
            const stop = stops[i];
            const activities = await apiFetch(`/api/activities?stop_id=${stop.id}`);
            
            const stopEl = document.createElement('div');
            stopEl.className = 'timeline-stop animate-up';
            stopEl.innerHTML = `
                <div class="stop-indicator">
                    <i class="fas fa-location-dot"></i>
                </div>
                <div class="card glass-card">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
                        <div>
                            <h3 style="font-size: 1.75rem; margin-bottom: 0.25rem;">${stop.city_name}</h3>
                            <span style="color: var(--primary); font-weight: 700; font-size: 0.9rem; display: flex; align-items: center; gap: 0.5rem;">
                                <i class="far fa-calendar-alt"></i>
                                ${formatDate(stop.arrival_date)} — ${formatDate(stop.departure_date)}
                            </span>
                        </div>
                        <div style="background: var(--primary-glow); color: var(--primary); padding: 0.5rem 1rem; border-radius: var(--radius-md); font-weight: 800; font-size: 0.75rem; letter-spacing: 0.05em;">
                            STOP ${i+1}
                        </div>
                    </div>
                    
                    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem;">
                        ${activities.length > 0 ? activities.map(act => `
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 1.25rem; background: rgba(255,255,255,0.5); border-radius: var(--radius-md); border: 1px solid var(--glass-border); transition: all 0.3s ease;" class="activity-item">
                                <div style="display: flex; align-items: center; gap: 1rem;">
                                    <div style="width: 40px; height: 40px; border-radius: 50%; background: white; display: flex; align-items: center; justify-content: center; color: var(--primary); font-size: 0.9rem; border: 1px solid var(--glass-border); box-shadow: var(--shadow-soft);">
                                        <i class="fas ${getActivityIcon(act.category)}"></i>
                                    </div>
                                    <div>
                                        <div style="font-weight: 700; color: var(--text-heading); font-size: 0.95rem;">${act.name}</div>
                                        <div style="font-size: 0.75rem; color: var(--text-dim); font-weight: 600;">${act.activity_time || 'All Day'}</div>
                                    </div>
                                </div>
                                <div style="font-weight: 800; color: var(--primary); font-size: 1rem;">₹${act.cost.toLocaleString()}</div>
                            </div>
                        `).join('') : `
                            <div style="grid-column: 1 / -1; text-align: center; padding: 3rem; border: 2px dashed var(--glass-border); border-radius: var(--radius-lg); color: var(--text-dim);">
                                <i class="fas fa-plus-circle" style="font-size: 1.5rem; opacity: 0.3; margin-bottom: 1rem; display: block;"></i>
                                <p style="font-size: 0.9rem; font-weight: 500;">No activities scheduled yet.</p>
                            </div>
                        `}
                    </div>
                </div>
            `;
            container.appendChild(stopEl);

            if (i < stops.length - 1) {
                const nextStop = stops[i+1];
                const connEl = document.createElement('div');
                connEl.className = 'stop-connection';
                connEl.style.cssText = 'position: relative; height: 100px; margin: -2rem 0 -1rem 1.25rem; border-left: 2px dashed var(--primary-glow); display: flex; align-items: center; padding-left: 3rem;';
                connEl.innerHTML = `
                    <div style="background: white; padding: 0.5rem 1.5rem; border-radius: var(--radius-pill); border: 1px solid var(--primary-glow); box-shadow: var(--shadow-soft); display: flex; align-items: center; gap: 1rem; font-size: 0.75rem; font-weight: 700; color: var(--primary);">
                        <i class="fas fa-plane" style="transform: rotate(90deg);"></i>
                        <span>JOURNEY TO ${nextStop.city_name.toUpperCase()}</span>
                    </div>
                `;
                container.appendChild(connEl);
            }
        }
    }

    function getActivityIcon(category) {
        const icons = {
            'Activities': 'fa-camera',
            'Food': 'fa-utensils',
            'Travel': 'fa-car',
            'Hotel': 'fa-hotel',
            'Shopping': 'fa-bag-shopping'
        };
        return icons[category] || 'fa-star';
    }
</script>

<script src="/js/budget.js"></script>
<%- include('partials/footer') %>

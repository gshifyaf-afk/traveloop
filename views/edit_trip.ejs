<%- include('partials/header') %>

<div style="display: flex; justify-content: center; padding: 4rem 0;">
    <div class="card glass-card" style="width: 100%; max-width: 600px; padding: 3rem;">
        <h1 style="margin-bottom: 0.5rem;">Trip Settings</h1>
        <p class="text-muted" style="margin-bottom: 2.5rem;">Update your journey details or manage sharing.</p>
        
        <form id="editTripForm">
            <input type="hidden" name="id" value="<%= trip.id %>">
            
            <div class="form-group">
                <label for="name">Journey Name</label>
                <input type="text" id="name" name="name" value="<%= trip.name %>" required>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <label for="start_date">Start Date</label>
                    <input type="date" id="start_date" name="start_date" value="<%= trip.start_date %>" required>
                </div>
                <div class="form-group">
                    <label for="end_date">End Date</label>
                    <input type="date" id="end_date" name="end_date" value="<%= trip.end_date %>" required>
                </div>
            </div>
            
            <div class="form-group">
                <label for="description">Trip Description</label>
                <textarea id="description" name="description" rows="4"><%= trip.description %></textarea>
            </div>
            
            <div class="form-group" style="padding: 1.5rem; background: var(--bg-base); border-radius: var(--radius-sm); border: 1px solid var(--border-light);">
                <label>Public Share Link</label>
                <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
                    <input type="text" readonly value="<%= `${process.env.APP_URL || 'http://localhost:3000'}/shared/${trip.public_token}` %>" id="shareLink" style="font-size: 0.875rem;">
                    <button type="button" class="btn btn-outline btn-small" onclick="copyLink()">Copy</button>
                </div>
                <p class="text-muted" style="font-size: 0.75rem; margin-top: 0.5rem;">Anyone with this link can view your itinerary.</p>
            </div>
            
            <div style="display: flex; flex-direction: column; gap: 1rem; margin-top: 2rem;">
                <button type="submit" class="btn btn-primary btn-block">Save Changes</button>
                <div style="display: flex; gap: 1rem;">
                    <button type="button" id="deleteTripBtn" class="btn btn-outline" style="color: var(--danger); border-color: var(--danger); flex: 1;">Delete Trip</button>
                    <a href="/my-trips" class="btn btn-outline" style="flex: 1; text-align: center;">Back to Trips</a>
                </div>
            </div>
        </form>
    </div>
</div>

<script>
    function copyLink() {
        const copyText = document.getElementById("shareLink");
        copyText.select();
        document.execCommand("copy");
        alert("Link copied!");
    }

    document.getElementById('editTripForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = Object.fromEntries(new FormData(e.target));
        const res = await fetch(`/api/trips/${data.id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        if (res.ok) alert('Trip settings updated!');
        else alert('Update failed');
    });

    document.getElementById('deleteTripBtn').addEventListener('click', async () => {
        if (!confirm('Are you sure you want to delete this journey? This action cannot be undone.')) return;
        const res = await fetch(`/api/trips/<%= trip.id %>`, { method: 'DELETE' });
        if (res.ok) window.location.href = '/my-trips';
        else alert('Delete failed');
    });
</script>
<%- include('partials/footer') %>

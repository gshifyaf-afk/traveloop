<%- include('partials/header') %>

<div class="container" style="max-width: 800px; margin-top: 4rem; margin-bottom: 6rem;">
    <div class="card glass-card animate-up" style="padding: 4rem;">
        <div style="display: flex; align-items: center; gap: 3rem; margin-bottom: 4rem; padding-bottom: 3rem; border-bottom: 1px solid var(--glass-border);">
            <div style="position: relative;">
                <div style="width: 120px; height: 120px; border-radius: 50%; background: var(--primary-glow); display: flex; align-items: center; justify-content: center; font-size: 3rem; color: var(--primary); font-weight: 800; border: 4px solid white; box-shadow: var(--shadow-soft);">
                    <%= user.name.charAt(0).toUpperCase() %>
                </div>
                <button style="position: absolute; bottom: 0; right: 0; width: 35px; height: 35px; border-radius: 50%; background: white; border: 1px solid var(--glass-border); color: var(--primary); display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: var(--shadow-sm);">
                    <i class="fas fa-camera" style="font-size: 0.8rem;"></i>
                </button>
            </div>
            <div>
                <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;"><%= user.name %></h1>
                <p class="text-dim" style="font-size: 1.1rem;"><i class="far fa-envelope" style="margin-right: 0.5rem;"></i> <%= user.email %></p>
                <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
                    <span class="badge" style="background: rgba(34, 197, 94, 0.1); color: #16a34a; padding: 0.4rem 1rem; border-radius: var(--radius-pill); font-weight: 700; font-size: 0.75rem;">VERIFIED EXPLORER</span>
                    <span class="badge" style="background: var(--primary-glow); color: var(--primary); padding: 0.4rem 1rem; border-radius: var(--radius-pill); font-weight: 700; font-size: 0.75rem;">PREMIUM MEMBER</span>
                </div>
            </div>
        </div>

        <form id="profileForm" style="display: flex; flex-direction: column; gap: 2.5rem;">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                <div class="form-group">
                    <label style="font-weight: 700; margin-bottom: 0.75rem; display: block; color: var(--text-heading);">Display Name</label>
                    <input type="text" name="name" value="<%= user.name %>" required style="padding: 1rem 1.5rem; border-radius: var(--radius-md); border: 1px solid var(--glass-border); background: rgba(255,255,255,0.5);">
                </div>
                <div class="form-group">
                    <label style="font-weight: 700; margin-bottom: 0.75rem; display: block; color: var(--text-heading);">Email Address</label>
                    <input type="email" name="email" value="<%= user.email %>" required style="padding: 1rem 1.5rem; border-radius: var(--radius-md); border: 1px solid var(--glass-border); background: rgba(255,255,255,0.5);">
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                <div class="form-group">
                    <label style="font-weight: 700; margin-bottom: 0.75rem; display: block; color: var(--text-heading);">Preferred Language</label>
                    <select name="language" style="padding: 1rem 1.5rem; border-radius: var(--radius-md); border: 1px solid var(--glass-border); background: rgba(255,255,255,0.5); width: 100%;">
                        <option value="en">English (US)</option>
                        <option value="en-IN">English (India)</option>
                        <option value="hi">Hindi</option>
                        <option value="es">Spanish</option>
                        <option value="fr">French</option>
                    </select>
                </div>
                <div class="form-group">
                    <label style="font-weight: 700; margin-bottom: 0.75rem; display: block; color: var(--text-heading);">Default Currency</label>
                    <select name="currency" style="padding: 1rem 1.5rem; border-radius: var(--radius-md); border: 1px solid var(--glass-border); background: rgba(255,255,255,0.5); width: 100%;">
                        <option value="INR" selected>Indian Rupee (₹)</option>
                        <option value="USD">US Dollar ($)</option>
                        <option value="EUR">Euro (€)</option>
                        <option value="GBP">British Pound (£)</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label style="font-weight: 700; margin-bottom: 0.75rem; display: block; color: var(--text-heading);">Saved Destinations (Preferred Regions)</label>
                <input type="text" name="saved_destinations" placeholder="e.g. Tamil Nadu, Kyoto, Swiss Alps" style="padding: 1rem 1.5rem; border-radius: var(--radius-md); border: 1px solid var(--glass-border); background: rgba(255,255,255,0.5);">
                <p style="font-size: 0.8rem; color: var(--text-dim); margin-top: 0.5rem;">Separated by commas. These help us recommend trips for you.</p>
            </div>

            <div style="display: flex; gap: 1.5rem; margin-top: 2rem; pt: 2rem; border-top: 1px solid var(--glass-border);">
                <button type="submit" class="btn btn-primary" style="padding: 1rem 3rem;">Save Profile Changes</button>
                <button type="button" class="btn btn-outline" style="padding: 1rem 2rem;">Change Password</button>
            </div>
        </form>
    </div>
</div>

<script>
    document.getElementById('profileForm').onsubmit = async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData.entries());
        
        const res = await fetch('/api/user/profile', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });

        if (res.ok) {
            alert('Profile updated successfully!');
            window.location.reload();
        } else {
            alert('Failed to update profile.');
        }
    };
</script>

<%- include('partials/footer') %>

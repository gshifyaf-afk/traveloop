<%- include('partials/header') %>

<div class="page-header" style="padding: 4rem 0; display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem;">
    <div>
        <h1 style="font-size: 3rem; margin-bottom: 0.5rem;">My Journeys</h1>
        <p class="text-dim" style="font-size: 1.1rem;">Explore your past, current, and future adventures.</p>
    </div>
    <a href="/trips/create" class="btn btn-primary">
        <i class="fas fa-plus-circle"></i> Create New Trip
    </a>
</div>

<div class="grid-cols-auto" style="gap: 2.5rem;">
    <% if (trips.length === 0) { %>
        <div class="card glass-card animate-up" style="grid-column: 1 / -1; text-align: center; padding: 6rem; border: 2px dashed var(--glass-border); background: transparent;">
            <div style="font-size: 4rem; margin-bottom: 2rem; color: var(--text-dim); opacity: 0.5;"><i class="fas fa-map-marked-alt"></i></div>
            <h2 style="font-size: 2rem; margin-bottom: 1rem;">No journeys found</h2>
            <p class="text-dim" style="margin-bottom: 3rem; font-size: 1.1rem;">Every great explorer starts with a single plan. Ready to create yours?</p>
            <a href="/trips/create" class="btn btn-primary btn-large">Start Planning Your First Trip</a>
        </div>
    <% } else { %>
        <% trips.forEach(trip => { %>
            <div class="card glass-card animate-up" style="display: flex; flex-direction: column; height: 100%; padding: 2.5rem;">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem;">
                    <div>
                        <h3 style="font-size: 1.75rem; margin-bottom: 0.5rem;"><%= trip.name %></h3>
                        <div style="display: flex; align-items: center; gap: 0.75rem; color: var(--primary); font-weight: 700; font-size: 0.9rem;">
                            <i class="far fa-calendar-alt"></i>
                            <span><%= trip.start_date %> — <%= trip.end_date %></span>
                        </div>
                    </div>
                    <div style="width: 50px; height: 50px; border-radius: 12px; background: var(--bg-main); display: flex; align-items: center; justify-content: center; color: var(--primary);">
                        <i class="fas fa-plane"></i>
                    </div>
                </div>
                <p class="text-dim" style="font-size: 1rem; margin-bottom: 2.5rem; flex-grow: 1; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.7;">
                    <%= trip.description || 'Embark on a unique journey to explore new cultures, sights, and experiences. Your adventure awaits!' %>
                </p>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <a href="/trips/view/<%= trip.id %>" class="btn btn-primary btn-small" style="justify-content: center;"><i class="fas fa-eye"></i> View</a>
                    <a href="/trips/itinerary/<%= trip.id %>" class="btn btn-outline btn-small" style="justify-content: center;"><i class="fas fa-tools"></i> Manage</a>
                </div>
                <div style="margin-top: 1.5rem; pt: 1rem; border-top: 1px solid var(--glass-border); display: flex; justify-content: center;">
                    <a href="/trips/edit/<%= trip.id %>" style="font-size: 0.8rem; color: var(--text-dim); text-decoration: none; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;">Settings & Sharing</a>
                </div>
            </div>
        <% }) %>
    <% } %>
</div>

<%- include('partials/footer') %>

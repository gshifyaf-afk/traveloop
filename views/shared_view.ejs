<%- include('partials/header') %>

<div class="shared-hero" style="padding: 6rem 1.5rem; text-align: center; background: white; border-bottom: 1px solid var(--glass-border); position: relative; overflow: hidden;">
    <div style="position: absolute; top: -100px; left: -100px; width: 300px; height: 300px; background: var(--primary-glow); border-radius: 50%; filter: blur(60px); opacity: 0.3;"></div>
    
    <div class="container animate-up">
        <span class="badge" style="background: var(--primary-glow); color: var(--primary); padding: 0.6rem 2rem; border-radius: var(--radius-pill); font-weight: 800; font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase;">Premium Shared Itinerary</span>
        <h1 style="font-size: clamp(2.5rem, 8vw, 4.5rem); margin: 1.5rem 0; letter-spacing: -0.04em;"><%= trip.name %></h1>
        <p class="text-dim" style="max-width: 700px; margin: 0 auto 3rem; font-size: 1.1rem; line-height: 1.8;"><%= trip.description %></p>
        
        <div style="display: flex; flex-direction: column; align-items: center; gap: 2rem;">
            <% if (typeof user !== 'undefined' && user) { %>
                <button id="copyTripBtn" class="btn btn-primary" data-token="<%= trip.public_token %>" style="padding: 1.2rem 3rem; font-size: 1.1rem; border-radius: var(--radius-pill);">
                    <i class="fas fa-copy"></i> Import this Journey to My Account
                </button>
            <% } else { %>
                <div class="card glass-card" style="padding: 2rem 4rem; border-radius: var(--radius-pill); display: flex; align-items: center; gap: 2rem; flex-wrap: wrap; justify-content: center;">
                    <p class="text-dim" style="margin: 0; font-weight: 600;">Found this journey inspiring?</p>
                    <div style="display: flex; gap: 1rem;">
                        <a href="/login" class="btn btn-outline btn-small">Log In</a>
                        <a href="/signup" class="btn btn-primary btn-small">Sign Up & Copy</a>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</div>

<div class="container" style="max-width: 900px; margin-top: 6rem;">
    <h2 style="text-align: center; margin-bottom: 5rem; font-size: 2rem;"><i class="fas fa-map-signs" style="color: var(--primary); margin-right: 1rem;"></i> The Travel Plan</h2>
    
    <div class="itinerary-timeline">
        <% stops.forEach((stop, index) => { %>
            <div class="timeline-stop animate-up">
                <div class="stop-indicator">
                    <i class="fas fa-location-arrow" style="font-size: 0.8rem;"></i>
                </div>
                <div class="card glass-card" style="padding: 2.5rem;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2.5rem; flex-wrap: wrap; gap: 1rem;">
                        <div>
                            <h3 style="font-size: 1.75rem; margin-bottom: 0.5rem;"><%= stop.city_name %></h3>
                            <span style="color: var(--primary); font-weight: 700; font-size: 0.9rem; display: flex; align-items: center; gap: 0.5rem;">
                                <i class="far fa-calendar-alt"></i> <%= stop.arrival_date %> — <%= stop.departure_date %>
                            </span>
                        </div>
                        <div style="background: var(--primary-glow); color: var(--primary); padding: 0.5rem 1rem; border-radius: var(--radius-md); font-weight: 800; font-size: 0.75rem;">
                            DESTINATION <%= index + 1 %>
                        </div>
                    </div>
                    
                    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem;">
                        <% if (stop.activities && stop.activities.length > 0) { %>
                            <% stop.activities.forEach(act => { %>
                                <div style="display: flex; justify-content: space-between; align-items: center; padding: 1.25rem; background: rgba(255,255,255,0.5); border-radius: var(--radius-md); border: 1px solid var(--glass-border); transition: all 0.3s ease;">
                                    <div style="display: flex; align-items: center; gap: 1rem;">
                                        <div style="width: 40px; height: 40px; border-radius: 50%; background: white; display: flex; align-items: center; justify-content: center; color: var(--primary); font-size: 0.9rem; border: 1px solid var(--glass-border); box-shadow: var(--shadow-soft);">
                                            <i class="fas <%= getIconForCategory(act.category) %>"></i>
                                        </div>
                                        <div>
                                            <div style="font-weight: 700; color: var(--text-heading); font-size: 0.95rem;"><%= act.name %></div>
                                            <div style="font-size: 0.75rem; color: var(--text-dim); font-weight: 600;"><%= act.activity_time || 'Planned' %> | <%= act.category %></div>
                                        </div>
                                    </div>
                                    <div style="font-weight: 800; color: var(--primary); font-size: 1.1rem;">₹<%= act.cost.toLocaleString() %></div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div style="grid-column: 1 / -1; text-align: center; padding: 3rem; border: 2px dashed var(--glass-border); border-radius: var(--radius-xl); color: var(--text-dim); font-style: italic;">
                                No specific activities scheduled for this destination.
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <% if (index < stops.length - 1) { %>
                <div class="stop-connection" style="position: relative; height: 100px; margin: -2rem 0 -1rem 1.25rem; border-left: 2px dashed var(--primary-glow); display: flex; align-items: center; padding-left: 3rem;">
                    <div style="background: white; padding: 0.5rem 1.5rem; border-radius: var(--radius-pill); border: 1px solid var(--primary-glow); box-shadow: var(--shadow-soft); display: flex; align-items: center; gap: 1rem; font-size: 0.75rem; font-weight: 700; color: var(--primary);">
                        <i class="fas fa-plane" style="transform: rotate(90deg);"></i>
                        <span>JOURNEY TO <%= stops[index+1].city_name.toUpperCase() %></span>
                    </div>
                </div>
            <% } %>
        <% }) %>
    </div>
</div>

<% 
function getIconForCategory(cat) {
    const icons = {
        'Activities': 'fa-camera',
        'Food': 'fa-utensils',
        'Travel': 'fa-car',
        'Hotel': 'fa-hotel',
        'Shopping': 'fa-bag-shopping'
    };
    return icons[cat] || 'fa-star';
}
%>

<script>
    document.getElementById('copyTripBtn')?.addEventListener('click', async (e) => {
        const token = e.target.closest('button').dataset.token;
        const res = await fetch('/api/copy-trip', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ token })
        });
        const result = await res.json();
        if (result.success) {
            alert('Journey successfully imported to your account!');
            window.location.href = `/trips/itinerary/${result.newTripId}`;
        } else {
            alert('Failed to import journey. Please try again.');
        }
    });
</script>
<%- include('partials/footer') %>
